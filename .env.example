# Eclipse Memory - Environment Configuration
# Copy to .env and fill in your values

# Server Configuration
NODE_ENV=production
PORT=50001
WS_PORT=50002
WHATSAPP_PORT=50003
HOST=0.0.0.0

# AI Model API Keys
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
KIMI_API_KEY=sk-kimi-...

# Google Integration (for WhatsApp lead routing)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:50001/auth/google/callback
WHATSAPP_LEAD_SHEET_ID=1KrDiddG7JMgZEsLRW5EvaeZsCyN_Ihs43ihfUpbV0pc

# Email Configuration
LEAD_EMAIL_RECIPIENT=DevHouse.app@gmail.com
LEAD_EMAIL_SENDER=Eclipse Memory <noreply@eclipse-memory.ai>
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# Memory Configuration
MEMORY_PATH=./memory
CONFIG_PATH=./config
VECTOR_DB_URL=http://localhost:8000
REDIS_URL=redis://localhost:6379

# WhatsApp Credentials
WHATSAPP_SESSION_NAME=eclipse-memory
WHATSAPP_WEBHOOK_URL=http://localhost:50003/webhook

# Development
DEBUG=false
LOG_LEVEL=INFO
